# Database Configuration
# Format: postgresql://username:password@host:port/database
# Note: If password contains @ symbol, encode it as %40
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/smartroute

# API Keys
# Get from: https://developer.tomtom.com/
TOMTOM_API_KEY=your_tomtom_api_key_here

# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Get from: https://console.cloud.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# Security Keys (generate random strings)
SECRET_KEY=your-secret-key-here-use-random-string
API_KEY_SALT=your-api-salt-here-use-random-string

# Server Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# ML Model Paths
TABNET_MODEL_PATH=models/tabnet
GNN_MODEL_PATH=models/gnn_model.pth

# Monitoring Locations (latitude,longitude pairs separated by semicolon)
# Default: Bangalore locations
MONITORING_LOCATIONS=12.97,77.59;12.93,77.62;12.92,77.62
